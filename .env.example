# Supabase (required for persistent call history in production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional legacy local SQLite (mock fallback used when Supabase is not configured)
DATABASE_URL="file:./dev.db"
JWT_SECRET="trace-dev-secret-change-in-production"
